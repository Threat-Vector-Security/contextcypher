      "commonTargets": ["Public-facing systems", "Network perimeter", "User credentials", "Valuable data"]
    },
    {
      "name": "Insider Threat",
      "description": "Threat actors within the organization",
      "motivations": ["Financial gain", "Revenge", "Ideology", "Accidental"],
      "capabilities": ["Privileged access", "System knowledge", "Physical access", "Social engineering"],
      "commonTargets": ["Internal systems", "Sensitive data", "Credentials", "Business processes"]
    },
    {
      "name": "Supply Chain Attacker",
      "description": "Threat actors targeting the supply chain",
      "motivations": ["Widespread impact", "Stealth access", "Long-term presence"],
      "capabilities": ["Code injection", "Hardware tampering", "Software compromise", "Update mechanisms"],
      "commonTargets": ["Third-party components", "Updates", "Dependencies", "Build systems"]
    },
    {
      "name": "Nation State",
      "description": "Government-sponsored threat actors",
      "motivations": ["Espionage", "Disruption", "Strategic advantage", "Intelligence gathering"],
      "capabilities": ["Advanced techniques", "Zero-day exploits", "Long-term campaigns", "Extensive resources"],
      "commonTargets": ["Critical infrastructure", "Government systems", "Intellectual property", "Strategic data"]
    }
  ],
