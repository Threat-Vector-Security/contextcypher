# Server Environment Configuration

# Node environment: production, development, test
NODE_ENV=development

# Server port (default: 3001)
PORT=3001

# Bind to all interfaces in development (for WSL/Playwright testing)
# Only set this to 'true' if you need external access in development
BIND_ALL_INTERFACES=false

# Application secret for API authentication
# IMPORTANT: Change this in production!
APP_SECRET=your-secure-secret-here

# AI Provider API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...

# Offline mode flag
OFFLINE_MODE=false

# GitHub token for threat intelligence (optional)
GITHUB_TOKEN=ghp_...