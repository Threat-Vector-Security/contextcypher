        "published": "2018-03-26T15:29:00.263",
        "lastModified": "2023-11-07T02:40:03.750",
        "vulnStatus": "Modified",
        "descriptions": [
          {
            "lang": "en",
            "value": "In Apache httpd 2.4.0 to 2.4.29, the expression specified in <FilesMatch> could match '$' to a newline character in a malicious filename, rather than matching only the end of the filename. This could be exploited in environments where uploads of some files are externally blocked, but only by matching the trailing portion of the filename."
          }
        ],
