      "T1059.001": {
        "name": "PowerShell",
        "tactic": "Execution",
        "description": "Adversaries may abuse PowerShell for execution",
        "detection": "PowerShell logging, Script block logging",
        "mitigation": ["Constrained Language Mode", "Disable PowerShell for users"]
      }
    },
    "detectionRules": {
      "T1566.001": {
        "sigma": "title: Suspicious Email Attachment\ndetection:\n  selection:\n    EventID: 4688\n    CommandLine|contains: 'outlook.exe'\n  condition: selection",
        "kql": "DeviceProcessEvents | where ProcessCommandLine contains 'outlook.exe' and ProcessCommandLine contains '.zip'",
        "splunk": "index=windows EventCode=4688 CommandLine=\"*outlook.exe*\" CommandLine=\"*.zip*\""
      },
      "T1078": {
        "sigma": "title: Multiple Failed Logins Followed by Success\ndetection:\n  selection:\n    EventID: \n      - 4625\n      - 4624\n  condition: selection",
        "kql": "SigninLogs | where ResultType != 0 | summarize FailedCount = count() by UserPrincipalName, bin(TimeGenerated, 5m)",
        "splunk": "index=windows (EventCode=4625 OR EventCode=4624) | transaction UserName maxspan=5m"
      }
    }
  },
